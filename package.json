{
  "name": "f1-grand-prix-analytics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "build:data:cached": "node scripts/build-data.mjs --cache-only",
    "build:pages": "node scripts/build-pages.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "build": "npm run build:data && npm run validate:data && npm run build:pages && vite build",
    "build:ui": "npm run build:pages && vite build",
    "dev": "npm run build:data && npm run validate:data && npm run build:pages && vite --host",
    "dev:ui": "npm run build:pages && vite --host",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "vite": "^7.1.12"
  }
}
